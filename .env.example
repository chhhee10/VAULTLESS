# Copy this to .env and fill in your values

# ── Ethereum ──────────────────────────────────────────────────
# Deploy VaultlessCore.sol on Remix IDE → Sepolia testnet
# Paste the deployed contract address here
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Alchemy RPC for Sepolia (optional — MetaMask handles this)
VITE_ALCHEMY_KEY=your_alchemy_api_key

# ── EmailJS Duress Alert ──────────────────────────────────────
# Create account at emailjs.com
# Create a service (Gmail works), create a template
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_ALERT_EMAIL=your.alert@email.com

# ── Demo Mode ─────────────────────────────────────────────────
# Set to "true" to run without MetaMask/Ethereum (simulates everything)
VITE_DEMO_MODE=true
